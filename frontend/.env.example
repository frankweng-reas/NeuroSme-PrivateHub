# 後端 API port，預設 8000。若 8000 被佔用可改 8001
# VITE_API_PORT=8001

# LocalAuth port（Vite proxy 用），預設 4000
# VITE_LOCALAUTH_PORT=4000

# LocalAuth 完整 URL。當 LocalAuth 在 Docker 且前端連線失敗時可設：
# - 本機：http://localhost:4000
# - 前端在 Docker 內需連 host：http://host.docker.internal:4000
# VITE_AUTH_API_URL=http://localhost:4000
