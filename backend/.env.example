# JWT（與 LocalAuth 共用，用於驗證 access_token）
JWT_SECRET=your-secret-key-here

# NeuroSme2.0 專用 PostgreSQL (docker compose up -d)
# port 5434 避免與 local auth 的 PostgreSQL 衝突
DATABASE_URL=postgresql://neurosme:neurosme_secret@localhost:5434/neurosme2

# LLM API（chat 測試頁使用）
OPENAI_API_KEY=sk-your-openai-api-key
# GEMINI_API_KEY=your-gemini-key
# 台智雲 Conversation API（公用模式）
# TWCC_API_KEY=your-twcc-api-key
# TWCC_API_BASE=https://api-ams.twcc.ai/api/models/conversation
# CORS 預設已包含 3000-3002，可覆寫
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]

# LocalAuth Admin API（後端代理用，勿暴露給前端）
# 僅 on-prem / REGISTRATION_DISABLED=true 場景需設定；SaaS 自助註冊時留空即可
# LOCALAUTH_ADMIN_URL=http://localhost:4000
# LOCALAUTH_ADMIN_API_KEY=your-strong-admin-api-key-here
